-------------------------------------------------------------------------------
-- Terminal Triage — CorsixTH configuration template
--
-- Copy this file to config.txt in the same directory, then set
-- theme_hospital_install to your Theme Hospital data path.
--
-- Launch the mod with:
--   CorsixTH.exe --lua-dir="<this-dir>\Lua" --config-file="<this-dir>\config.txt"
--   corsix-th  --lua-dir="<this-dir>/Lua"  --config-file="<this-dir>/config.txt"
--
-- All folder paths that are NOT explicitly set below will default to the
-- directory containing this config.txt file.  So Levels/, Campaigns/, and
-- Saves/ resolve to TerminalTriage/ automatically when this file is used.
-------------------------------------------------------------------------------

-------------------------------------------------------------------------------
-- REQUIRED: Point this to your Theme Hospital install directory.
-- This is the folder that contains HOSPITAL.EXE (or the GOG data files).
-- Do NOT leave this as the placeholder value or the game will not start.
-------------------------------------------------------------------------------
theme_hospital_install = [[C:\Path\To\ThemeHospital]]

-------------------------------------------------------------------------------
-- Display settings
-------------------------------------------------------------------------------
-- fullscreen = false
-- width = 1280
-- height = 720

-------------------------------------------------------------------------------
-- Language
-- Use "English" until the Terminal Triage language file is ready (Phase 1).
-- Once the language file is in place, switch to "Terminal Triage".
-------------------------------------------------------------------------------
language = [[English]]

-------------------------------------------------------------------------------
-- Folder overrides
-- Saves/, Levels/, and Screenshots/ resolve relative to config.txt by default.
--
-- IMPORTANT: 'campaigns' MUST be set to TerminalTriage/UserCampaigns/ (or any
-- folder other than TerminalTriage/Campaigns/).  CorsixTH scans both
-- campaign_dir (= TerminalTriage/Campaigns/ via getFullPath) and
-- user_campaign_dir (= derived from config.txt location).  If both point to
-- the same folder the mod campaign appears as a duplicate in the menu.
-------------------------------------------------------------------------------
-- savegames   = [[C:\Path\To\TerminalTriage\Saves]]
-- levels      = [[C:\Path\To\TerminalTriage\Levels]]
campaigns      = [[C:\Path\To\TerminalTriage\UserCampaigns]]
-- screenshots = [[C:\Path\To\TerminalTriage\Screenshots]]

-------------------------------------------------------------------------------
-- Graphics overrides (Phase 3/4 — leave commented out until art assets exist)
--
-- use_new_graphics = true  enables custom animation loading from Graphics/.
-- When enabled, CorsixTH reads TerminalTriage/Graphics/file_mapping.txt and
-- loads each .dat animation file listed there.
--
-- new_graphics_folder is optional; omit it to use the default path which the
-- App:getFullPath override already directs to TerminalTriage/Graphics/.
-- Only set it if you need to point at a different directory.
--
-- LIMITATION: only animation (.dat) overrides are supported.  Sprite sheets
-- are always loaded from the original Theme Hospital install.
--
-- use_new_graphics    = true
-- new_graphics_folder = [[C:\Path\To\TerminalTriage\Graphics]]
-------------------------------------------------------------------------------

-------------------------------------------------------------------------------
-- Audio settings
-------------------------------------------------------------------------------
audio = true
-- audio_music = [[C:\Path\To\TerminalTriage\Music]]

-------------------------------------------------------------------------------
-- Gameplay
-------------------------------------------------------------------------------
enable_announcer_subtitles = true
autosave_frequency = 1
